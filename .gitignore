# ------------------------------
# Java 通用编译产物
# ------------------------------
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# 日志与崩溃文件
*.log
logs/
application.log
hs_err_pid*
replay_pid*

# ------------------------------
# Maven 构建相关
# ------------------------------
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ------------------------------
# IntelliJ IDEA 编辑器配置
# ------------------------------
.idea/
*.iws
*.ipr
*.iml
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ------------------------------
# 系统临时/缓存文件
# ------------------------------
# Windows
Thumbs.db
# MacOS
.DS_Store
# 通用临时文件
*.tmp
*.temp
.cache

# ------------------------------
# Spring Boot 专属
# ------------------------------
# 分环境配置文件（保留主配置，忽略环境专属配置）
application-*.yml
application-*.yaml
application-*.properties
!application.yml
!application.yaml
!application.properties

# 开发工具相关
devtools/

# ------------------------------
# 测试与本地环境
# ------------------------------
surefire-reports/
test-output/
# 本地环境变量（防止密钥泄露）
.env
.env.local
.env.*.local